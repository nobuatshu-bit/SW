# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development
HTTP_ADDRESS=:8080
CORS_ORIGINS=http://localhost:3000

# ── Data stores ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://sherwood:sherwood@localhost:5432/sherwood?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be ≥ 32 characters in production
JWT_SECRET=changeme-replace-with-a-secure-random-value-in-production
JWT_EXPIRY_HOURS=24

# ── Blockchain ────────────────────────────────────────────────────────────────
# Base Sepolia public RPC (replace with a private endpoint for production)
BASE_RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# ── Observability ─────────────────────────────────────────────────────────────
# Accepted values: debug | info | warn | error
LOG_LEVEL=debug
